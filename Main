<body>

<h1>Password Strength & Crack Time Simulator</h1>

<div class="box">

  <div class="row">
    <label>Password Length: <span id="lenVal">8</span></label>
    <input type="range" min="4" max="32" value="8" id="length">
  </div>

  <div class="row">
    <label><input type="checkbox" id="lower" checked> Lowercase</label>
    <label><input type="checkbox" id="upper" checked> Uppercase</label>
    <label><input type="checkbox" id="nums" checked> Numbers</label>
    <label><input type="checkbox" id="symbols"> Symbols</label>
  </div>

  <div class="strength">
    <div class="bar" id="bar"></div>
  </div>

  <div class="result" id="output"></div>

</div>

<div class="quote">
  “Longer passwords or passphrases are significantly more resistant to guessing attacks.”
  <br>— NIST Digital Identity Guidelines (SP 800-63B)
</div>

<script>
const lengthSlider = document.getElementById("length");
const lenVal = document.getElementById("lenVal");

const lower = document.getElementById("lower");
const upper = document.getElementById("upper");
const nums = document.getElementById("nums");
const symbols = document.getElementById("symbols");

const bar = document.getElementById("bar");
const output = document.getElementById("output");

function calc() {
  let length = parseInt(lengthSlider.value);
  lenVal.textContent = length;

  let charset = 0;
  if (lower.checked) charset += 26;
  if (upper.checked) charset += 26;
  if (nums.checked) charset += 10;
  if (symbols.checked) charset += 32;

  if (charset === 0) charset = 1;

  // entropy estimate
  let entropy = length * Math.log2(charset);

  // guesses per second (theoretical offline attack)
  let guessesPerSecond = 1e10;

  let totalCombinations = Math.pow(charset, length);
  let seconds = totalCombinations / guessesPerSecond;

  let years = seconds / (60*60*24*365);

  // strength %
  let strength = Math.min(100, entropy * 2);

  bar.style.width = strength + "%";

  if (strength < 30) bar.style.background = "red";
  else if (strength < 70) bar.style.background = "orange";
  else bar.style.background = "green";

  output.innerHTML =
    `Entropy: ${entropy.toFixed(1)} bits<br>` +
    `Time to crack: ${years > 1e6 ? "millions of years+" : years.toFixed(2) + " years"}`;
}

document.querySelectorAll("input").forEach(el => {
  el.addEventListener("input", calc);
});

calc();
</script>

